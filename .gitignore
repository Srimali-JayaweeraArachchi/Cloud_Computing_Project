# ========================================
# Node.js / JavaScript
# ========================================
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================================
# Environment Variables - VERY IMPORTANT
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Also ignore .env files explicitly in services (extra safety)
user-service/.env
restaurant-service/.env
order-service/.env
notification-service/.env

# ========================================
# Docker
# ========================================
.dockerignore

# ========================================
# OS generated files
# ========================================
.DS_Store
Thumbs.db

# ========================================
# IDE / Editor
# ========================================
.vscode/
.idea/
*.swp
*.swo

# ========================================
# Build outputs
# ========================================
dist/
build/
coverage/

# ========================================
